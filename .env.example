# Keep "/" for the current root-domain production deployment.
# Only change this when the built app is served from a subdirectory.
VITE_BASE_PATH=/
# Optional: override the GitHub username used by the project catalog fetch.
VITE_GITHUB_USERNAME=abhinaykhalatkar
# Optional: canonical site URL used for SEO tags, structured data, and sitemap validation.
# Include protocol and omit query/hash. Example: https://example.com/
VITE_SITE_URL=https://abhinaykhalatkar.de/
# Optional: override the Home page timeline feed JSON URL.
VITE_TIMELINE_SOURCE_URL=/data/linkedin-timeline.json
